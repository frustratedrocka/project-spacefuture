F; --note: #2D2A2E; --outer-bar: #19181A; --side-bar: #221F22; --dark-sidebar: #000000; --bttn: #403E41; --sidebar-icon-color-active: #FFD866; --nav-item-background-hover: #000000; --file-icon-color: #FFD866; --folder: #FC9867; --folder-open: #FC9867; --headers: #FFD866; --list-marker-color: #FF6188; --list-numbered-color: #FC9867; --embed-bg: #221F22; --blockquote-border-color: #403E41; --code-bg: #221F22; --code-text: #FF6188; --th-text: #FC9867; --accent: #FFD866; --lite-accent: #FC9867; --accent2: #3C5274; --accent2-lite: #78DCE8; --dark-accent: #19181A; --deep-dark-accent: #1D191C; --inactive: #7C7C7B; --bg: #19181A; --lines: #403E41; --fg: #CFD7DD; --theme-rainbow-1: #19181A; --theme-rainbow-2: #221F22; --theme-rainbow-3: #2D2A2E; --theme-rainbow-4: #403E41; --theme-rainbow-5: #7C7C7B; --theme-rainbow-6: #C9C9C7; --text-highlight-bg: rgb(171,157,242); --highlight: rgb(53,65,87); --text-highlight-bg-active: rgb(252,152,103); --hvr: rgba(255,216,102,0.25); --hvr-active: rgba(255,216,102,0.5); --graph-lines: #403E41; --graph-node: #7C7C7B; --graph-focused: #FFD866; }
